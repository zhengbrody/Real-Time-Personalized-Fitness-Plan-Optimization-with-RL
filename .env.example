# ProFit AI Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# OpenAI Configuration
# ============================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model to use for AI Coach (gpt-4, gpt-3.5-turbo, etc.)
AGENT_MODEL=gpt-4

# ============================================
# Database Configuration
# ============================================
# SQLite (local development)
DATABASE_URL=sqlite:///data/fitness.db

# PostgreSQL (production - uncomment to use)
# DATABASE_URL=postgresql://user:password@localhost:5432/profit_ai

# ============================================
# Kafka Configuration
# ============================================
# For local development
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# For Docker environment
# KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# Kafka topics
KAFKA_FEEDBACK_TOPIC=user_feedback
KAFKA_EVENTS_TOPIC=training_events

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis cache TTL (seconds)
CACHE_TTL=3600

# ============================================
# Feature Store Configuration
# ============================================
# Feast feature store
FEAST_REPO_PATH=src/feature_store/
FEATURE_SERVING_ENDPOINT=http://localhost:6566

# ============================================
# Model Serving Configuration
# ============================================
# TorchServe
TORCHSERVE_MANAGEMENT_API=http://localhost:8081
TORCHSERVE_INFERENCE_API=http://localhost:8080

# Model paths
MODEL_PATH=models/
CHECKPOINT_PATH=models/checkpoints/

# ============================================
# API Configuration
# ============================================
# API server settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# CORS settings (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# ============================================
# Web Interface Configuration
# ============================================
# Streamlit settings
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true

# Theme
STREAMLIT_THEME=light

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# Log file paths
LOG_FILE=logs/profit_ai.log
ERROR_LOG_FILE=logs/errors.log

# ============================================
# Security Configuration
# ============================================
# Secret key for JWT tokens (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here

# Token expiration (seconds)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# External API Configuration
# ============================================
# Apple HealthKit (future)
APPLE_HEALTH_CLIENT_ID=
APPLE_HEALTH_CLIENT_SECRET=

# Oura Ring API
# Get your key from: https://cloud.ouraring.com/personal-access-tokens
OURA_API_KEY=
OURA_API_URL=https://api.ouraring.com/v2

# ============================================
# Development Settings
# ============================================
# Debug mode (set to 'false' in production!)
DEBUG=true

# Enable/disable features
ENABLE_AI_COACH=true
ENABLE_ONLINE_LEARNING=true
ENABLE_AB_TESTING=false

# Mock external services (for testing)
MOCK_OURA_API=false
MOCK_APPLE_HEALTH=false

# ============================================
# Monitoring & Observability
# ============================================
# Sentry (error tracking)
SENTRY_DSN=

# Prometheus metrics
ENABLE_METRICS=true
METRICS_PORT=9090

# ============================================
# Production Settings (uncomment for production)
# ============================================
# ENV=production
# DEBUG=false
# LOG_LEVEL=WARNING
# ENABLE_METRICS=true
# RATE_LIMIT_PER_MINUTE=30
